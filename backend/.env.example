# PRGuard Backend Configuration

# ────────────────────────────────────────────────────────────────────────────
# 🔑 GITHUB OAUTH (Required for User Auth)
# ────────────────────────────────────────────────────────────────────────────
GITHUB_APP_ID=your_github_app_id
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret
GITHUB_PRIVATE_KEY_PATH=./private-key.pem

# ────────────────────────────────────────────────────────────────────────────
# 🤖 LLM PROVIDERS (Choose at least one)
# ────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=your_gemini_api_key

# ────────────────────────────────────────────────────────────────────────────
# 💾 DATABASE
# ────────────────────────────────────────────────────────────────────────────
# Required. Use your cloud PostgreSQL connection string here.
# Example (Neon pooler):
# postgresql://user:password@your-project-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL=
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_CONNECT_RETRIES=3
DB_CONNECT_TIMEOUT=10
DB_RETRY_DELAY_SECONDS=0.5
DB_MAX_RETRY_DELAY_SECONDS=5

# ────────────────────────────────────────────────────────────────────────────
# 🔄 CACHE & QUEUE (Redis)  
# ────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ────────────────────────────────────────────────────────────────────────────
# 🏠 APPLICATION URLs
# ────────────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5175
APP_URL=http://localhost:8000

# For production, use:
# FRONTEND_URL=https://your-domain.com
# APP_URL=https://api.your-domain.com

# ────────────────────────────────────────────────────────────────────────────
# 🔒 SECURITY
# ────────────────────────────────────────────────────────────────────────────
SECRET_KEY=your-random-secret-key-generate-this
JWT_SECRET=your-jwt-secret-key
SESSION_SECRET=your-session-secret-key

# ────────────────────────────────────────────────────────────────────────────
# 👤 ADMIN AUTHENTICATION (for /admin routes)
# ────────────────────────────────────────────────────────────────────────────
ADMIN_USERNAME=anirudhs23
ADMIN_PASSWORD=your-admin-password
ADMIN_EMAIL=admin@example.com
ADMIN_SESSION_TTL_SECONDS=43200  # 12 hours

# ────────────────────────────────────────────────────────────────────────────
# 🧠 RAG (Retrieval Augmented Generation)
# ────────────────────────────────────────────────────────────────────────────
CHROMA_DB_PATH=./chroma_db
PRELOAD_RAG_ON_STARTUP=false

# ────────────────────────────────────────────────────────────────────────────
# 🌐 ENVIRONMENT & LOGGING
# ────────────────────────────────────────────────────────────────────────────
# Required in deployment platforms (Render/Railway/Vercel backend):
# DATABASE_URL must be set or startup fails fast.
ENVIRONMENT=development
NODE_ENV=development
DEBUG=false
PORT=8000

# ────────────────────────────────────────────────────────────────────────────
# 🔗 LANGCHAIN (Optional)
# ────────────────────────────────────────────────────────────────────────────
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=prguard
LANGCHAIN_TRACING_V2=true

# ────────────────────────────────────────────────────────────────────────────
# CORS & LEGACY (Deprecated)
# ────────────────────────────────────────────────────────────────────────────
# CORS_ORIGINS=http://localhost:5175,http://localhost:3000
# ADMIN_USERS=user1,user2  # (Deprecated - use ADMIN_USERNAME instead)
