# ────────────────────────────────────────────────────────────────────────────
# Frontend Environment Variables (Vite)
# ────────────────────────────────────────────────────────────────────────────
# These are REQUIRED and must be set BEFORE building for production.
# They get baked into the dist build and cannot be changed at runtime.

# Backend API Base URL (Required for production builds)
# Must match your deployed backend domain
# Example: https://api.yourdomain.com or https://backend.yourdomain.com
VITE_API_BASE_URL=https://api.yourdomain.com

# GitHub OAuth Client ID (Required for user authentication)
# Must match the CLIENT_ID registered in your GitHub OAuth App
VITE_GITHUB_CLIENT_ID=your_github_oauth_client_id

# ────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT NOTES:
# ────────────────────────────────────────────────────────────────────────────
# 1. These env vars are embedded in the compiled dist/ during "npm run build"
# 2. Frontend runs as static files served from Coolify or CDN
# 3. API requests go to VITE_API_BASE_URL with credentials: true
# 4. Update before each deployment if domains change
# ────────────────────────────────────────────────────────────────────────────
