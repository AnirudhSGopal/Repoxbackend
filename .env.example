# ────────────────────────────────────────────────────────────────────────────
# PRGuard Deployment Configuration
# Coolify + Supabase PostgreSQL + Optional Redis
# ────────────────────────────────────────────────────────────────────────────

# REQUIRED: Database Connection
# Use Supabase PostgreSQL pooler endpoint for best performance
DATABASE_URL=postgresql+asyncpg://postgres:password@db.project-ref.supabase.co:6543/postgres?sslmode=require

# OPTIONAL: Redis Cache & Queue (remove if not using)
# If not configured, app gracefully degrades to database-only mode
REDIS_URL=redis://:<password>@redis-host:6379/0

# REQUIRED: Security Keys
SECRET_KEY=replace-with-strong-random-secret-min-32-chars
JWT_SECRET=replace-with-strong-random-secret
SESSION_SECRET=replace-with-strong-random-secret

# REQUIRED: Domain Configuration
# These control OAuth redirect URIs and CORS
APP_URL=https://api.yourdomain.com
FRONTEND_URL=https://app.yourdomain.com
CORS_ORIGINS=https://app.yourdomain.com

# REQUIRED: Environment
ENVIRONMENT=production
PORT=8000

# REQUIRED: GitHub OAuth
GITHUB_CLIENT_ID=your_github_app_client_id
GITHUB_CLIENT_SECRET=your_github_app_client_secret
GITHUB_APP_ID=your_github_app_id
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# OPTIONAL: LLM Providers (at least one recommended)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# OPTIONAL: LLM Configuration
MODEL_PROVIDER=gemini
MODEL_NAME=gemini-2.5-flash
CHAT_ENABLE_RAG=false
PRELOAD_RAG_ON_STARTUP=false

# OPTIONAL: Admin Bootstrap
# Set only if using local admin auth (not recommended for production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_EMAIL=admin@yourdomain.com

# Frontend Frontend Configuration (Set before frontend build)
VITE_API_BASE_URL=https://api.yourdomain.com
VITE_GITHUB_CLIENT_ID=your_github_app_client_id
