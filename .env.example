ENVIRONMENT=production
PORT=8000

# Backend URLs
APP_URL=https://api.yourdomain.com
FRONTEND_URL=https://app.yourdomain.com
CORS_ORIGINS=https://app.yourdomain.com

# Security
SECRET_KEY=replace-with-strong-random-secret
GITHUB_WEBHOOK_SECRET=replace-with-webhook-secret

# GitHub OAuth/App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=./private-key.pem

# Admin authentication bootstrap
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-admin-password
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_USERS=admin

# LLM providers (optional when using per-user API keys)
MODEL_PROVIDER=gemini
MODEL_NAME=gemini-2.5-flash
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Data stores
DATABASE_URL=postgresql://user:password@your-project-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=change-me

# Optional observability
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=prguard
LANGCHAIN_TRACING_V2=true

# RAG behavior
CHAT_ENABLE_RAG=false
PRELOAD_RAG_ON_STARTUP=false

# Frontend (for build-time config)
VITE_API_BASE_URL=https://api.yourdomain.com
VITE_GITHUB_CLIENT_ID=
