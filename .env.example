# PRGuard Backend Configuration

# ────────────────────────────────────────────────────────────────────────────
# 🔑 GITHUB OAUTH (Required for User Auth)
# ────────────────────────────────────────────────────────────────────────────
GITHUB_APP_ID=your_github_app_id
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret
GITHUB_PRIVATE_KEY_PATH=./private-key.pem

# ────────────────────────────────────────────────────────────────────────────
# 🤖 LLM PROVIDERS (Choose at least one)
# ────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=your_gemini_api_key
LLM_API_KEY=

# ────────────────────────────────────────────────────────────────────────────
# 💾 DATABASE
# ────────────────────────────────────────────────────────────────────────────
# Required. Neon pooler recommended in production.
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<your-neon-pooler-host>/<db>?sslmode=require&channel_binding=require
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_CONNECT_RETRIES=3
DB_CONNECT_TIMEOUT=10
DB_RETRY_DELAY_SECONDS=0.5
DB_MAX_RETRY_DELAY_SECONDS=5

# ────────────────────────────────────────────────────────────────────────────
# 🔄 CACHE & QUEUE (Redis)
# ────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:<password>@<your-redis-host>:6379/0

# ────────────────────────────────────────────────────────────────────────────
# 🏠 APPLICATION URLS
# ────────────────────────────────────────────────────────────────────────────
APP_URL=https://api.yourdomain.com
FRONTEND_URL=https://app.yourdomain.com
CORS_ORIGINS=https://app.yourdomain.com

# ────────────────────────────────────────────────────────────────────────────
# 🔒 SECURITY
# ────────────────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-strong-random-secret
JWT_SECRET=replace-with-jwt-secret
SESSION_SECRET=replace-with-session-secret

# ────────────────────────────────────────────────────────────────────────────
# 👤 ADMIN
# ────────────────────────────────────────────────────────────────────────────
ADMIN_USERNAME=prguard_admin
ADMIN_PASSWORD=replace-with-admin-password
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_SESSION_TTL_SECONDS=43200

# ────────────────────────────────────────────────────────────────────────────
# 🌐 ENVIRONMENT
# ────────────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
NODE_ENV=production
DEBUG=false
PORT=8000
